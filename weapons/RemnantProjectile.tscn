[gd_scene format=3 uid="uid://co85dhq0weh6u"]

[sub_resource type="GDScript" id="GDScript_iu4oj"]
script/source = "extends Node3D

# ── Config ────────────────────────────────────────────────────────────────────
var speed: float = 60.0
var damage: float = 45.0
var lifetime: float = 3.0       # seconds before auto-destroy
var elapsed: float = 0.0

# ── References ────────────────────────────────────────────────────────────────
@onready var hit_particles: GPUParticles3D = $HitParticles
@onready var trail_particles: GPUParticles3D = $TrailParticles
@onready var ray: RayCast3D = $RayCast3D

func setup(p_speed: float, p_damage: float) -> void:
	speed = p_speed
	damage = p_damage

func _physics_process(delta: float) -> void:
	elapsed += delta
	if elapsed >= lifetime:
		queue_free()
		return

	# Move forward
	var direction = -global_transform.basis.z
	global_position += direction * speed * delta

	# Check raycast hit
	if ray.is_colliding():
		var hit = ray.get_collider()
		_on_hit(hit)

func _on_hit(body: Node) -> void:
	# Deal damage if enemy
	if body.has_method(\"take_damage\"):
		body.take_damage(damage)

	# Hit particles
	if hit_particles:
		hit_particles.emitting = true
		# Detach so it stays at hit position after projectile is gone
		hit_particles.reparent(get_tree().root)
		var cleanup_timer = get_tree().create_timer(1.0)
		cleanup_timer.timeout.connect(hit_particles.queue_free)

	queue_free()
"

