[gd_scene format=3 uid="uid://blenit6xr3wp6"]

[sub_resource type="GDScript" id="GDScript_ceoee"]
script/source = "extends Node3D

@export var speed: float = 120.0
@export var lifetime: float = 0.06

var elapsed: float = 0.0
var direction: Vector3 = Vector3.ZERO

func setup(from: Vector3, dir: Vector3) -> void:
	direction = dir.normalized()
	global_position = from + direction * 1.0  # start just ahead of camera
	# Rotate so the box length points along direction
	if direction != Vector3.ZERO:
		var xform = Transform3D()
		xform.basis = Basis.looking_at(direction, Vector3.UP)
		global_transform.basis = xform.basis

func _process(delta: float) -> void:
	elapsed += delta
	global_position += direction * speed * delta
	if elapsed >= lifetime:
		queue_free()
"

